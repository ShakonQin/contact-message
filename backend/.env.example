# 聊天 Agent + 总结 Agent (OpenAI 兼容格式，可与上面相同或不同)
CHAT_AGENT_BASE_URL=https://api-inference.modelscope.cn/v1
CHAT_AGENT_API_KEY=your_api_key_here
